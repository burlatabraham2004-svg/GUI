btn_save = tk.Button(root, text="Save Data", width=12, command=save_student)
btn_save.grid(row=9, column=0, pady=10)

btn_show = tk.Button(root, text="Show Data", width=12, command=show_data)
btn_show.grid(row=9, column=1, pady=10)

# ---------------- OUTPUT ---------------- #
tk.Label(root, text="Average Grade:", font=("Arial", 11, "bold")).grid(row=10, column=0, pady=5)

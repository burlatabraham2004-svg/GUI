import tkinter as tk
from tkinter import ttk, messagebox

# ---------------- DATA ---------------- #
students_data = []  # To store all saved student info

# ---------------- FUNCTIONS ---------------- #

def compute_grade():
    try:
        prelim = float(entry_prelim.get())
        midterm = float(entry_midterm.get())
        final = float(entry_final.get())

        if not all(0 <= grade <= 100 for grade in [prelim, midterm, final]):
            messagebox.showerror("Invalid Input", "Grades must be between 0 and 100")
            return

        average = (prelim * 0.30) + (midterm * 0.30) + (final * 0.40)

        if 97 <= average <= 100:
            numerical, remark = "1.00", "Excellent"
        elif 94 <= average <= 96:
            numerical, remark = "1.25", "Excellent"
        elif 91 <= average <= 93:
            numerical, remark = "1.50", "Very Good"
        elif 88 <= average <= 90:
            numerical, remark = "1.75", "Very Good"
        elif 85 <= average <= 87:
            numerical, remark = "2.00", "Above Average"
        elif 82 <= average <= 84:
            numerical, remark = "2.25", "Above Average"
        elif 79 <= average <= 81:
            numerical, remark = "2.50", "Average"
        elif 76 <= average <= 78:
            numerical, remark = "2.75", "Average"
        elif average == 75:
            numerical, remark = "3.00", "Passing"
        elif 72 <= average <= 74:
            numerical, remark = "3.25", "Conditional"
        elif 69 <= average <= 71:
            numerical, remark = "3.50", "Conditional"
        elif 66 <= average <= 68:
            numerical, remark = "3.75", "Failed"
        elif average == 65:
            numerical, remark = "4.00", "Failed"
        else:
            numerical, remark = "5.00", "Failed"

        label_average.config(text=f"{average:.2f}")
        label_numerical.config(text=numerical)
        label_remark.config(text=remark)

    except ValueError:
        messagebox.showerror("Error", "Please enter valid numeric grades")

def clear_fields():
    entry_id.delete(0, tk.END)
    entry_name.delete(0, tk.END)
    entry_subject.delete(0, tk.END)
    entry_prelim.delete(0, tk.END)
    entry_midterm.delete(0, tk.END)
    entry_final.delete(0, tk.END)
    combo_course.current(0)
    label_average.config(text="")
    label_numerical.config(text="")
    label_remark.config(text="")

def save_student():
    # Make sure compute_grade is done first
    if label_average.cget("text") == "":
        messagebox.showerror("Error", "Please compute the grade first")
        return

    student = {
        "Student ID": entry_id.get(),
        "Student Name": entry_name.get(),
        "Course": combo_course.get(),
        "Subject": entry_subject.get(),
        "Prelim": entry_prelim.get(),
        "Midterm": entry_midterm.get(),
        "Final": entry_final.get(),
        "Average": label_average.cget("text"),
        "Numerical": label_numerical.cget("text"),
        "Remark": label_remark.cget("text")
    }
    students_data.append(student)
    messagebox.showinfo("Saved", "Student data saved successfully!")

def show_data():
    if not students_data:
        messagebox.showinfo("No Data", "No student data saved yet!")
        return

    data_window = tk.Toplevel(root)
    data_window.title("Saved Student Data")
    data_window.geometry("900x400")

    tree = ttk.Treeview(data_window)
    tree.pack(fill=tk.BOTH, expand=True)

    # Define columns
    columns = ["Student ID", "Student Name", "Course", "Subject", "Prelim", "Midterm", "Final", "Average", "Numerical", "Remark"]
    tree["columns"] = columns
    tree["show"] = "headings"

    for col in columns:
        tree.heading(col, text=col)
        tree.column(col, width=80, anchor="center")

    # Insert data
    for student in students_data:
        tree.insert("", tk.END, values=[student[col] for col in columns])

# Optional: Print course selection
def course_selected(event):
    print("Selected course:", combo_course.get())

# ---------------- WINDOW ---------------- #

